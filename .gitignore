# =========================
# Virtual environments
# =========================
.venv/
venv/
ENV/
env/
.envrc

# =========================
# Environment variables
# =========================
# production env
.env
.env.*

# allow example files
!.env.example

# test env files
.test.env
.test.env.*

# explicitly allow test example
!.test.env.example


# =========================
# Python cache
# =========================
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd

# =========================
# Tests / tools cache
# =========================
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/

# =========================
# IDE (PyCharm / VSCode)
# =========================
.idea/
.vscode/
*.swp
*.swo

# =========================
# OS files
# =========================
.DS_Store
Thumbs.db

# =========================
# Logs
# =========================
*.log
logs/

# =========================
# Distribution / build
# =========================
dist/
build/
*.egg-info/
.eggs/

# =========================
# Docker (optional)
# =========================
*.pid

# =========================
# Jupyter Notebook
# =========================
.ipynb_checkpoints/

# =========================
# JWT / SSL / Keys
# =========================
certs/*.pem
certs/*.key
certs/*.crt

**/private*.pem
**/*private*.key
